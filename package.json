{
  "name": "tempo-explorer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "build:api": "tsc api/**/*.ts --outDir .vercel/output/functions",
    "check": "tsc --noEmit",
    "vercel-build": "npm run build"
  },
  "dependencies": {
    "viem": "latest",
    "hono": "latest",
    "@hono/node-server": "latest",
    "@hono/node-ws": "latest",
    "@vercel/node": "latest",
    "@upstash/redis": "latest"
  },
  "devDependencies": {
    "typescript": "^5",
    "vite": "latest",
    "@vitejs/plugin-react": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4",
    "@tailwindcss/vite": "^4",
    "tsx": "latest",
    "concurrently": "latest"
  }
}
